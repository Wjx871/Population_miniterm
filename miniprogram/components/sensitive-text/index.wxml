<view class="sensitive-text {{expandable ? 'sensitive-text--collapsible' : 'sensitive-text--plain'}} {{expanded ? 'sensitive-text--expanded' : ''}}">
  <text class="sensitive-value">{{value || '—'}}</text>
  <button
    wx:if="{{expandable}}"
    class="expand-button"
    size="mini"
    bindtap="toggle"
  >{{expanded ? '收起' : '展开'}}</button>
</view>
