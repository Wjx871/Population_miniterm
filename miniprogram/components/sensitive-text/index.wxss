.sensitive-text {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  min-width: 0;
  max-width: 100%;
}

.sensitive-value {
  display: -webkit-box;
  min-width: 0;
  flex: 1;
  overflow: hidden;
  color: inherit;
  line-height: 1.55;
  overflow-wrap: anywhere;
  word-break: break-word;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.sensitive-text--expanded .sensitive-value,
.sensitive-text--plain .sensitive-value {
  display: block;
  overflow: visible;
  -webkit-line-clamp: initial;
}

.expand-button {
  min-width: 72rpx;
  margin: 0;
  padding: 0 10rpx;
  flex-shrink: 0;
  color: #1677ff;
  font-size: 22rpx;
  line-height: 40rpx;
  background: transparent;
  border: 0;
}
