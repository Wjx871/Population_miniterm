.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 220rpx;
  padding: 40rpx 24rpx;
  color: #667085;
}

.loading-state--compact {
  min-height: 112rpx;
  padding: 24rpx;
}

.spinner {
  width: 34rpx;
  height: 34rpx;
  border: 5rpx solid #d9e7f8;
  border-top-color: #1677ff;
  border-radius: 50%;
  animation: loading-spin 800ms linear infinite;
}

.loading-text {
  margin-top: 16rpx;
  font-size: 24rpx;
}

.loading-placeholder {
  width: 72%;
  max-width: 440rpx;
  margin-top: 24rpx;
}

.placeholder-line {
  width: 68%;
  height: 12rpx;
  margin: 12rpx auto 0;
  background: #e8eef6;
  border-radius: 999rpx;
}

.placeholder-line--wide {
  width: 100%;
}

@keyframes loading-spin {
  to {
    transform: rotate(360deg);
  }
}
