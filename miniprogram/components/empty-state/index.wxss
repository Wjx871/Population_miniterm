.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 260rpx;
  padding: 42rpx 28rpx;
  text-align: center;
  background: #fff;
  border: 1rpx dashed #d8e1ed;
  border-radius: 20rpx;
}

.empty-icon {
  position: relative;
  width: 78rpx;
  height: 64rpx;
  margin-bottom: 22rpx;
}

.empty-icon__tray {
  position: absolute;
  right: 4rpx;
  bottom: 2rpx;
  left: 4rpx;
  height: 40rpx;
  border: 4rpx solid #b8c7da;
  border-top: 0;
  border-radius: 0 0 14rpx 14rpx;
}

.empty-icon__line {
  position: absolute;
  top: 8rpx;
  left: 19rpx;
  width: 40rpx;
  height: 4rpx;
  background: #1677ff;
  border-radius: 999rpx;
  box-shadow: 0 15rpx 0 #d4deea;
}

.empty-title {
  color: #17233d;
  font-size: 28rpx;
  font-weight: 600;
}

.empty-description {
  max-width: 520rpx;
  margin-top: 10rpx;
  color: #8a94a6;
  font-size: 24rpx;
  line-height: 1.55;
}

.empty-action {
  margin-top: 24rpx;
  padding: 0 28rpx;
  color: #1677ff;
  background: #fff;
  border: 1rpx solid rgba(22, 119, 255, 0.55);
  border-radius: 999rpx;
}
