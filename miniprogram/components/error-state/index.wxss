.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 260rpx;
  padding: 42rpx 28rpx;
  text-align: center;
  background: #fff;
  border: 1rpx solid #f2d9da;
  border-radius: 20rpx;
}

.error-icon {
  width: 62rpx;
  height: 62rpx;
  color: #e5484d;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 62rpx;
  background: #fff0f0;
  border-radius: 50%;
}

.error-state--forbidden .error-icon,
.error-state--conflict .error-icon {
  color: #a15c00;
  background: #fff5df;
}

.error-state--network .error-icon,
.error-state--unauthorized .error-icon,
.error-state--notFound .error-icon {
  color: #1677ff;
  background: #eaf3ff;
}

.error-title {
  margin-top: 20rpx;
  color: #17233d;
  font-size: 28rpx;
  font-weight: 650;
}

.error-description {
  max-width: 540rpx;
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.55;
  overflow-wrap: anywhere;
}

.retry-button {
  margin-top: 24rpx;
  padding: 0 28rpx;
  color: #1677ff;
  background: #fff;
  border: 1rpx solid rgba(22, 119, 255, 0.55);
  border-radius: 999rpx;
}
