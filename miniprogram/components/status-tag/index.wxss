.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  max-width: 100%;
  color: #1677ff;
  font-weight: 600;
  line-height: 1;
  white-space: nowrap;
  background: #eaf3ff;
  border: 1rpx solid rgba(22, 119, 255, 0.12);
  border-radius: 999rpx;
  vertical-align: middle;
}

.tag--medium {
  min-height: 36rpx;
  padding: 7rpx 16rpx;
  font-size: 22rpx;
  line-height: 22rpx;
}

.tag--small {
  min-height: 30rpx;
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  line-height: 22rpx;
}

.tag--info {
  color: #1677ff;
  background: #eaf3ff;
  border-color: rgba(22, 119, 255, 0.12);
}

.tag--primary {
  color: #1677ff;
  background: #eaf3ff;
  border-color: rgba(22, 119, 255, 0.18);
}

.tag--success {
  color: #18794e;
  background: #e9f8f0;
  border-color: rgba(34, 160, 107, 0.14);
}

.tag--warning {
  color: #a15c00;
  background: #fff5df;
  border-color: rgba(245, 158, 11, 0.18);
}

.tag--danger {
  color: #c7353a;
  background: #fff0f0;
  border-color: rgba(229, 72, 77, 0.16);
}

.tag--neutral {
  color: #667085;
  background: #f2f4f7;
  border-color: rgba(152, 162, 179, 0.18);
}
