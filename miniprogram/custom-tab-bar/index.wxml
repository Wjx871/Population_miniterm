<view class="tab-bar">
  <view
    class="tab-item {{selected === index ? 'tab-item--selected' : ''}}"
    wx:for="{{list}}"
    wx:key="pagePath"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <view class="tab-icon">
      <app-icon
        name="{{item.icon}}"
        size="40"
        color="{{selected === index ? selectedColor : color}}"
      />
    </view>
    <text class="tab-label">{{item.text}}</text>
  </view>
</view>
