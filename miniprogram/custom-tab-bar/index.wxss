:host {
  display: block;
}

.tab-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 1000;
  display: flex;
  height: 104rpx;
  padding-bottom: env(safe-area-inset-bottom);
  color: #8a94a6;
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid #e5eaf2;
  box-shadow: 0 -8rpx 28rpx rgba(18, 59, 122, 0.08);
}

.tab-item {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  flex-direction: column;
  gap: 2rpx;
  color: #8a94a6;
}

.tab-item--selected {
  color: #1677ff;
}

.tab-item--selected::before {
  position: absolute;
  top: 0;
  width: 42rpx;
  height: 5rpx;
  background: #1677ff;
  border-radius: 0 0 999rpx 999rpx;
  content: '';
}

.tab-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 52rpx;
}

.tab-label {
  font-size: 21rpx;
  font-weight: 500;
  line-height: 1.2;
}

.tab-item--selected .tab-label {
  font-weight: 650;
}
