:host {
  display: block;
}

.tab-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 1000;
  display: flex;
  width: 100%;
  min-height: calc(116rpx + constant(safe-area-inset-bottom));
  min-height: calc(116rpx + env(safe-area-inset-bottom));
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
  color: #8a94a6;
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid #e5eaf2;
  box-shadow: 0 -8rpx 28rpx rgba(18, 59, 122, 0.08);
}

.tab-item {
  position: relative;
  display: flex;
  min-width: 0;
  min-height: 116rpx;
  padding: 12rpx 0 10rpx;
  align-items: center;
  justify-content: center;
  flex: 1;
  flex-direction: column;
  gap: 8rpx;
  box-sizing: border-box;
  color: #8a94a6;
}

.tab-item--selected {
  color: #1677ff;
}

.tab-item--selected::before {
  position: absolute;
  top: 0;
  width: 42rpx;
  height: 5rpx;
  background: #1677ff;
  border-radius: 0 0 999rpx 999rpx;
  content: '';
}

.tab-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
}

.tab-label {
  font-size: 21rpx;
  font-weight: 600;
  line-height: 28rpx;
  white-space: nowrap;
}
