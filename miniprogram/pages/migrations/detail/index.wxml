<view class="page"><loading-state wx:if="{{loading}}" text="正在加载迁移记录…" /><error-state wx:elif="{{error}}" message="{{error}}" bindretry="load" /><block wx:else><view class="summary-card"><view class="section-heading"><app-icon name="{{record.migrationType === 'MIGRATION_OUT' ? 'migration-out' : 'migration-in'}}" size="40" tone="deep" /><view class="section-title">{{record.personName}} · {{record.migrationTypeDisplay}}</view></view><view class="row-between"><text class="hint">{{record.applicationNoDisplay}}</text><status-tag text="{{record.statusDisplay}}" type="{{record.statusTone}}" size="small" /></view></view><view class="card"><view class="field"><text class="label">来源区域</text><text class="value">{{record.sourceRegionDisplay}}</text></view><view class="field"><text class="label">目标区域</text><text class="value">{{record.targetRegionDisplay}}</text></view><view class="field"><text class="label">执行日期</text><text class="value">{{record.executeDateDisplay}}</text></view><view class="field"><text class="label">执行时间</text><text class="value">{{record.executedAtDisplay}}</text></view></view><view wx:if="{{application}}" class="card" bindtap="openApplication"><view class="row-between"><view><view class="item-title">查看完整申请进度</view><view class="hint">{{application.nextStepDisplay}}</view></view><app-icon name="chevron-right" size="28" tone="primary" /></view></view></block></view>
