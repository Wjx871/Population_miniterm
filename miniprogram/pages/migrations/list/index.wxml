<view class="page">
  <view class="hero"><view class="hero-icon"><app-icon name="migration-in" size="48" color="#fff" /></view><view><view class="hero-title">迁移记录查询</view><view class="hero-desc">查询迁入、迁出申请与执行结果</view></view></view>
  <view class="card filter-card">
    <view class="filter-stack"><view class="input-shell"><input class="filter-input" placeholder="人员姓名" value="{{personName}}" bindinput="inputName" /></view><view class="input-shell"><input class="filter-input" placeholder="申请编号" value="{{applicationNo}}" bindinput="inputNo" /></view><picker range="{{typeOptions}}" range-key="label" value="{{typeIndex}}" bindchange="changeType"><view class="picker-shell row-between"><text>{{typeOptions[typeIndex].label}}</text><app-icon name="chevron-down" size="24" tone="muted" /></view></picker></view>
    <view class="search-actions"><button class="primary" bindtap="search">查询</button><button class="ghost" bindtap="reset">重置</button></view>
  </view>
  <view class="result-head row-between"><view class="section-title">查询结果</view><text class="result-note">{{totalDisplay}} 条</text></view>
  <loading-state wx:if="{{loading}}" text="正在加载迁移记录…" />
  <error-state wx:elif="{{error}}" message="{{error}}" bindretry="search" />
  <empty-state wx:elif="{{!records.length}}" title="暂无迁移记录" description="请调整查询条件后重试" />
  <block wx:else>
    <view class="business-item list-card" wx:for="{{records}}" wx:key="migrationId" data-no="{{item.applicationNo}}" bindtap="open"><view class="item-icon"><app-icon name="{{item.migrationType === 'MIGRATION_OUT' ? 'migration-out' : 'migration-in'}}" size="40" tone="primary" /></view><view class="item-main"><view class="row-between"><view class="item-title">{{item.personName}} · {{item.migrationTypeDisplay}}</view><status-tag text="{{item.statusDisplay}}" type="{{item.statusTone}}" size="small" /></view><view class="item-line">申请编号：{{item.applicationNoDisplay}}</view><view class="item-meta"><text>{{item.sourceRegionDisplay}}</text><text>至</text><text>{{item.targetRegionDisplay}}</text></view></view><app-icon name="chevron-right" size="28" tone="muted" /></view>
    <loading-state wx:if="{{loadingMore}}" text="加载更多…" /><view wx:if="{{last && records.length}}" class="end">已加载全部记录</view>
  </block>
</view>
