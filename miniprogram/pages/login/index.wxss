.login-page{min-height:100vh;padding:110rpx 48rpx calc(50rpx + env(safe-area-inset-bottom));background:linear-gradient(160deg,#eaf4ff,#f8fbff 52%,#eef5fb)}.brand{text-align:center;margin-bottom:55rpx}.emblem{width:112rpx;height:112rpx;line-height:112rpx;margin:0 auto 24rpx;border-radius:30rpx;background:#1769aa;color:#fff;font-size:50rpx;font-weight:700;box-shadow:0 14rpx 32rpx rgba(23,105,170,.25)}.brand-title{font-size:40rpx;font-weight:700}.brand-subtitle{color:#6c7c8f;margin-top:12rpx}.login-card{background:#fff;border-radius:24rpx;padding:42rpx;box-shadow:0 18rpx 55rpx rgba(28,74,112,.12)}.password-wrap{position:relative}.password{padding-right:110rpx}.toggle{position:absolute;right:22rpx;top:25rpx;color:#1769aa}.remember{display:flex;align-items:center;gap:12rpx;color:#667587;margin:5rpx 0 28rpx}.box{width:34rpx;height:34rpx;border:1rpx solid #9caaba;border-radius:6rpx;text-align:center;line-height:32rpx;color:#1769aa}.login-error{color:#b53138;background:#fff0f0;padding:16rpx;border-radius:10rpx;margin-bottom:18rpx}.security{text-align:center;color:#8996a5;font-size:24rpx;margin-top:40rpx}
