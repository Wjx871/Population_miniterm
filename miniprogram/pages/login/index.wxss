.login-page {
  min-height: 100vh;
  padding: calc(48rpx + env(safe-area-inset-top)) 40rpx calc(36rpx + env(safe-area-inset-bottom));
  overflow-x: hidden;
  background: linear-gradient(180deg, #edf5ff 0, #f3f7fc 360rpx, #f3f7fc 100%);
}

.brand-section {
  margin-bottom: 36rpx;
  text-align: center;
}

.brand-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 148rpx;
  height: 112rpx;
  margin: 0 auto 24rpx;
  background: #fff;
  border: 2rpx solid rgba(22, 119, 255, 0.2);
  border-radius: 34rpx;
  box-shadow: 0 12rpx 30rpx rgba(18, 59, 122, 0.12);
}

.brand-logo {
  display: block;
  width: 136rpx;
  height: 96rpx;
}

.brand-title {
  color: #0b2f6b;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.35;
}

.brand-subtitle {
  margin-top: 8rpx;
  color: #123b7a;
  font-size: 27rpx;
  font-weight: 600;
}

.brand-values {
  margin-top: 12rpx;
  color: #667085;
  font-size: 23rpx;
  letter-spacing: 2rpx;
}

.login-card {
  margin-bottom: 26rpx;
  padding: 34rpx 32rpx 32rpx;
}

.form-heading {
  color: #17233d;
  font-size: 32rpx;
  font-weight: 650;
}

.form-description {
  margin: 6rpx 0 28rpx;
  color: #8a94a6;
  font-size: 24rpx;
}

.input-row {
  position: relative;
  display: flex;
  align-items: center;
  min-width: 0;
  height: 88rpx;
  margin-bottom: 20rpx;
  padding: 0 18rpx;
  background: #f8faff;
  border: 1rpx solid #e5eaf2;
  border-radius: 16rpx;
}

.input-symbol {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
  color: #1677ff;
  font-size: 20rpx;
  background: #eaf3ff;
  border-radius: 14rpx;
}

.login-input {
  min-width: 0;
  height: 86rpx;
  flex: 1;
  color: #17233d;
  font-size: 27rpx;
}

.password-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  margin: 0;
  padding: 0;
  color: #1677ff;
  background: transparent;
}

.password-row {
  display: grid;
  grid-template-columns: 48rpx minmax(0, 1fr) 88rpx;
  column-gap: 14rpx;
  padding: 0 0 0 18rpx;
}

.password-row .input-symbol {
  margin-right: 0;
}

.password-input {
  width: 100%;
  padding: 0;
  box-sizing: border-box;
}

.form-options {
  display: flex;
  align-items: center;
  min-height: 58rpx;
  margin: 0 0 22rpx;
  color: #667085;
  font-size: 24rpx;
}

.checkbox {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.option-note {
  margin-left: auto;
  color: #8a94a6;
  font-size: 22rpx;
}

.login-error {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding: 16rpx 18rpx;
  color: #c7353a;
  font-size: 24rpx;
  line-height: 1.5;
  background: #fff0f0;
  border: 1rpx solid rgba(229, 72, 77, 0.14);
  border-radius: 14rpx;
}

.login-button {
  width: 100%;
  margin: 0;
}

.security-note {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  gap: 14rpx;
  padding: 8rpx 20rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.5;
}

.security-icon {
  display: flex;
  width: 34rpx;
  height: 34rpx;
  margin-top: 2rpx;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
}

.security-subtext {
  margin-top: 2rpx;
  color: #8a94a6;
  font-size: 21rpx;
}

@media (max-height: 620px) {
  .login-page {
    padding-top: calc(24rpx + env(safe-area-inset-top));
  }

  .brand-section {
    margin-bottom: 24rpx;
  }

  .brand-mark {
    width: 124rpx;
    height: 92rpx;
    margin-bottom: 14rpx;
  }

  .brand-logo {
    width: 114rpx;
    height: 80rpx;
  }

  .brand-values {
    margin-top: 6rpx;
  }
}
