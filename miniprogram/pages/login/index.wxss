.login-page {
  min-height: 100vh;
  padding: calc(48rpx + env(safe-area-inset-top)) 40rpx calc(36rpx + env(safe-area-inset-bottom));
  overflow-x: hidden;
  background: linear-gradient(180deg, #edf5ff 0, #f3f7fc 360rpx, #f3f7fc 100%);
}

.brand-section {
  margin-bottom: 36rpx;
  text-align: center;
}

.brand-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 108rpx;
  height: 108rpx;
  margin: 0 auto 22rpx;
  background: #fff;
  border: 2rpx solid rgba(22, 119, 255, 0.18);
  border-radius: 32rpx;
  box-shadow: 0 10rpx 28rpx rgba(22, 51, 92, 0.1);
}

.brand-mark__ring {
  position: relative;
  width: 70rpx;
  height: 70rpx;
  border: 5rpx solid #123b7a;
  border-radius: 50%;
}

.brand-mark__person {
  position: absolute;
  bottom: 12rpx;
  width: 16rpx;
  height: 24rpx;
  background: #1677ff;
  border-radius: 10rpx 10rpx 7rpx 7rpx;
}

.brand-mark__person::before {
  position: absolute;
  top: -15rpx;
  left: 2rpx;
  width: 12rpx;
  height: 12rpx;
  background: #1677ff;
  border-radius: 50%;
  content: '';
}

.brand-mark__person--main {
  left: 22rpx;
  width: 18rpx;
  height: 30rpx;
  background: #0b2f6b;
}

.brand-mark__person--main::before {
  width: 14rpx;
  height: 14rpx;
  background: #0b2f6b;
}

.brand-mark__person--left {
  left: 7rpx;
}

.brand-mark__person--right {
  right: 7rpx;
}

.brand-title {
  color: #0b2f6b;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.35;
}

.brand-subtitle {
  margin-top: 8rpx;
  color: #123b7a;
  font-size: 27rpx;
  font-weight: 600;
}

.brand-values {
  margin-top: 12rpx;
  color: #667085;
  font-size: 23rpx;
  letter-spacing: 2rpx;
}

.login-card {
  margin-bottom: 26rpx;
  padding: 34rpx 32rpx 32rpx;
}

.form-heading {
  color: #17233d;
  font-size: 32rpx;
  font-weight: 650;
}

.form-description {
  margin: 6rpx 0 28rpx;
  color: #8a94a6;
  font-size: 24rpx;
}

.input-row {
  display: flex;
  align-items: center;
  min-width: 0;
  height: 88rpx;
  margin-bottom: 20rpx;
  padding: 0 18rpx;
  background: #f8faff;
  border: 1rpx solid #e5eaf2;
  border-radius: 16rpx;
}

.input-symbol {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
  color: #1677ff;
  font-size: 20rpx;
  background: #eaf3ff;
  border-radius: 12rpx;
}

.login-input {
  min-width: 0;
  height: 86rpx;
  flex: 1;
  color: #17233d;
  font-size: 27rpx;
}

.password-toggle {
  min-width: 76rpx;
  height: 56rpx;
  margin: 0 0 0 8rpx;
  padding: 0 8rpx;
  flex-shrink: 0;
  color: #1677ff;
  font-size: 23rpx;
  line-height: 56rpx;
  background: transparent;
}

.form-options {
  display: flex;
  align-items: center;
  min-height: 58rpx;
  margin: 0 0 22rpx;
  color: #667085;
  font-size: 24rpx;
}

.checkbox {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  margin-right: 12rpx;
  color: #fff;
  border: 2rpx solid #98a2b3;
  border-radius: 8rpx;
}

.checkbox--checked {
  background: #1677ff;
  border-color: #1677ff;
}

.option-note {
  margin-left: auto;
  color: #8a94a6;
  font-size: 22rpx;
}

.login-error {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding: 16rpx 18rpx;
  color: #c7353a;
  font-size: 24rpx;
  line-height: 1.5;
  background: #fff0f0;
  border: 1rpx solid rgba(229, 72, 77, 0.14);
  border-radius: 14rpx;
}

.error-dot {
  width: 30rpx;
  height: 30rpx;
  flex-shrink: 0;
  text-align: center;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 30rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
}

.login-button {
  width: 100%;
  margin: 0;
}

.security-note {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  gap: 14rpx;
  padding: 8rpx 20rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.5;
}

.security-icon {
  width: 32rpx;
  height: 32rpx;
  margin-top: 2rpx;
  flex-shrink: 0;
  color: #1677ff;
  text-align: center;
  line-height: 30rpx;
  border: 2rpx solid #1677ff;
  border-radius: 50%;
}

.security-subtext {
  margin-top: 2rpx;
  color: #8a94a6;
  font-size: 21rpx;
}

@media (max-height: 620px) {
  .login-page {
    padding-top: calc(24rpx + env(safe-area-inset-top));
  }

  .brand-section {
    margin-bottom: 24rpx;
  }

  .brand-mark {
    width: 88rpx;
    height: 88rpx;
    margin-bottom: 14rpx;
  }

  .brand-values {
    margin-top: 6rpx;
  }
}
