<view class="login-page">
  <view class="brand"><view class="emblem">数</view><view class="brand-title">人口数据库管理系统</view><view class="brand-subtitle">内部移动管理端 V1</view></view>
  <view class="login-card">
    <input class="input" placeholder="用户名" value="{{username}}" bindinput="inputUsername" />
    <view class="password-wrap"><input class="input password" placeholder="密码" password="{{!showPassword}}" value="{{password}}" bindinput="inputPassword" /><text class="toggle" bindtap="togglePassword">{{showPassword?'隐藏':'显示'}}</text></view>
    <view class="remember" bindtap="toggleRemember"><text class="box">{{remember?'✓':''}}</text><text>记住账号（不保存密码）</text></view>
    <view wx:if="{{error}}" class="login-error">{{error}}</view>
    <button class="primary" loading="{{loading}}" disabled="{{loading}}" bindtap="submit">{{loading?'正在登录':'登录'}}</button>
  </view>
  <view class="security">仅限内部授权人员使用 · 敏感数据以服务端脱敏结果为准</view>
</view>
