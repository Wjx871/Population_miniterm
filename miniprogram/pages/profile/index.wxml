<view class="page tab-page">
  <view class="profile card"><view class="avatar">{{user.avatarText}}</view><view><view class="title name">{{user.displayName}}</view><view class="muted">@{{user.username || '—'}}</view></view></view>
  <view class="card"><view class="section-title">账号信息</view><view class="field"><text class="label">角色</text><text class="value">{{user.roleDisplay}}</text></view><view class="field"><text class="label">数据范围</text><text class="value">{{user.dataScopeDisplay}}</text></view><view class="field"><text class="label">部门</text><text class="value">{{user.departmentName || '—'}}</text></view><view class="field"><text class="label">区域编码</text><text class="value">{{user.regionCode || '—'}}</text></view></view>
  <view class="card"><view class="section-title">当前权限摘要</view><view class="permissions"><text wx:for="{{user.permissions}}" wx:key="*this">{{item}}</text><text wx:if="{{!user.permissions.length}}" class="muted">暂无权限</text></view></view>
  <view class="card"><view class="row-between"><view class="section-title health-title">后端健康状态</view><text class="link" bindtap="loadHealth">刷新</text></view><loading-state wx:if="{{loading}}" text="检测中…"/><error-state wx:elif="{{error}}" message="{{error}}" bindretry="loadHealth"/><view wx:else><view class="field"><text class="label">数据库</text><text class="value">{{health.database}}</text></view><view class="field"><text class="label">缓存模式</text><text class="value">{{health.cache}}</text></view><view class="field"><text class="label">Redis</text><text class="value">{{health.redis}}</text></view></view></view>
  <view class="safe-actions"><button class="danger" loading="{{loggingOut}}" disabled="{{loggingOut}}" bindtap="logout">退出登录</button></view>
</view>
