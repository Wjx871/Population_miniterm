<view class="page">
  <view class="hero">
    <view class="hero-icon"><app-icon name="permission" size="48" color="#fff" /></view>
    <view><view class="hero-title">{{user.displayName}}的权限</view><view class="hero-desc">权限由系统管理员统一配置</view></view>
  </view>
  <view class="card">
    <view class="section-title">工作职责</view>
    <empty-state wx:if="{{!user.duties.length}}" title="暂无工作职责" description="请联系系统管理员配置" />
    <block wx:else>
      <view class="material-row" wx:for="{{user.duties}}" wx:key="key"><app-icon name="check-circle" size="28" tone="success" /><text class="material-main">{{item.label}}</text></view>
    </block>
  </view>
  <view class="card">
    <view class="section-title">可用功能</view>
    <empty-state wx:if="{{!user.features.length}}" title="暂无可用功能" description="请联系系统管理员配置" />
    <block wx:else>
      <view class="material-row" wx:for="{{user.features}}" wx:key="key" data-url="{{item.url}}" bindtap="open"><app-icon name="{{item.icon}}" size="32" tone="primary" /><view class="material-main"><view class="material-name">{{item.title}}</view><view class="material-state">{{item.description}}</view></view><app-icon name="chevron-right" size="26" tone="muted" /></view>
    </block>
  </view>
  <view class="notice-card">本页仅说明当前账号已获得的移动端能力，不展示内部权限代码。</view>
</view>
