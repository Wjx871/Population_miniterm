.profile{display:flex;align-items:center;gap:24rpx;padding:30rpx;background:linear-gradient(135deg,#123b7a,#2563d9);border:0}.avatar{width:104rpx;height:104rpx;line-height:104rpx;text-align:center;flex-shrink:0;color:#123b7a;font-size:42rpx;font-weight:700;background:#fff;border-radius:28rpx}.profile-main{min-width:0;flex:1}.name{margin:0 0 6rpx;color:#fff}.role-row{display:flex;align-items:center;flex-wrap:wrap;gap:14rpx;color:#e7f1ff;font-size:24rpx}.account-status{padding:3rpx 10rpx;color:#d8f7e9;font-size:21rpx;background:rgba(34,160,107,.24);border-radius:999rpx}.account-status .status-dot{margin-right:6rpx}.username{margin-top:5rpx;color:#c8d9f4;font-size:22rpx}.duty-list{display:flex;flex-direction:column;gap:18rpx}.duty-item{display:flex;align-items:flex-start;gap:14rpx;color:#344054}.duty-dot{width:12rpx;height:12rpx;margin-top:15rpx;flex-shrink:0;background:#1677ff;border-radius:50%}.feature-list{display:flex;flex-direction:column}.feature-item{display:flex;align-items:center;gap:18rpx;padding:18rpx 0;border-bottom:1rpx solid #edf1f5}.feature-item:last-child{border-bottom:0}.feature-item:active{opacity:.72}.feature-icon{display:flex;align-items:center;justify-content:center;width:66rpx;height:66rpx;flex-shrink:0;background:#eaf3ff;border-radius:18rpx}.feature-copy{min-width:0;flex:1}.feature-title{font-weight:650}.feature-description{margin-top:2rpx;color:#7b8798;font-size:22rpx}.system-description{color:#667085;font-size:24rpx}.privacy-note{display:flex;align-items:flex-start;gap:12rpx;margin-top:20rpx;padding:18rpx;color:#123b7a;font-size:23rpx;background:#edf5ff;border-radius:14rpx}.privacy-note text{min-width:0;flex:1}.safe-actions{padding-top:6rpx}.safe-actions .danger-outline-button{background:#f3f7fc!important}
