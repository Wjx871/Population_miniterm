<view class="page">
  <view class="card"><input class="input" placeholder="姓名" value="{{name}}" bindinput="inputName"/><input class="input" placeholder="身份证号（按后端支持精确查询）" value="{{idCard}}" bindinput="inputIdCard"/><view class="search-actions"><button class="primary" bindtap="search">查询</button><button class="ghost" bindtap="reset">重置</button></view></view>
  <view class="row-between result-title"><view class="section-title">查询结果</view><text class="muted">共 {{total}} 条</text></view>
  <loading-state wx:if="{{loading}}"/><error-state wx:elif="{{error}}" message="{{error}}" bindretry="search"/><empty-state wx:elif="{{!records.length}}" text="未查询到人口记录"/>
  <view wx:else><view class="person card" wx:for="{{records}}" wx:key="personId" data-id="{{item.personId}}" bindtap="open"><view class="row-between"><view class="person-name">{{item.name}}</view><status-tag text="{{item.statusDisplay}}"/></view><view class="muted line">身份证号：{{item.idCardDisplay}}</view><view class="muted line">联系电话：{{item.phoneDisplay}}</view><view class="link detail-link"><text>查看详情</text><app-icon name="chevron-right" size="24" /></view></view><loading-state wx:if="{{loadingMore}}" text="加载更多…"/><view wx:if="{{last && records.length}}" class="end">已加载全部记录</view></view>
</view>
