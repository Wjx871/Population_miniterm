.person-detail-page {
  overflow-x: hidden;
}

.person-summary {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 28rpx;
  background: linear-gradient(145deg, #fff, #f7fbff);
}

.summary-avatar,
.section-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: #eaf3ff;
}

.summary-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
}

.summary-main {
  min-width: 0;
  flex: 1;
}

.summary-heading {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
}

.summary-name {
  min-width: 0;
  flex: 1;
  color: #0b2f6b;
  font-size: 36rpx;
  font-weight: 700;
  overflow-wrap: anywhere;
}

.summary-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 18rpx;
  margin-top: 10rpx;
  color: #667085;
  font-size: 23rpx;
}

.detail-section {
  padding-top: 24rpx;
}

.section-heading {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.section-heading .section-title {
  margin: 0;
  font-size: 29rpx;
}

.section-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
}

.field .sensitive-value {
  min-width: 0;
  flex: 1;
}

.long-value,
.sensitive-value {
  overflow-wrap: anywhere;
  word-break: break-word;
}

.household-relation {
  padding-top: 2rpx;
}

.relation-action {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 5rpx;
  padding-top: 20rpx;
  color: #1677ff;
  font-size: 24rpx;
}

.migration-summary {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #e5eaf2;
}

.migration-summary:last-child {
  border-bottom: 0;
}
