<view class="page"><loading-state wx:if="{{loading}}"/><error-state wx:elif="{{error}}" message="{{error}}" bindretry="load"/><view wx:else>
  <view class="card"><view class="row-between"><view class="title">{{person.name}}</view><status-tag text="{{person.statusDisplay}}"/></view><view class="field"><text class="label">性别</text><text class="value">{{person.genderDisplay}}</text></view><view class="field"><text class="label">出生日期</text><text class="value">{{person.birthDateDisplay}}</text></view><view class="field"><text class="label">民族</text><text class="value">{{person.ethnicityDisplay}}</text></view><view class="field"><text class="label">身份证号</text><sensitive-text class="value" value="{{person.idCardDisplay}}" expandable/></view><view class="field"><text class="label">联系电话</text><sensitive-text class="value" value="{{person.phoneDisplay}}"/></view><view class="field"><text class="label">当前地址</text><sensitive-text class="value" value="{{person.addressDisplay}}" expandable/></view></view>
  <view class="card"><view class="section-title">当前户籍与家庭关系</view><view wx:if="{{household}}"><view class="field"><text class="label">户籍编号</text><text class="value link" bindtap="openHousehold">{{household.householdNo || '—'}} ›</text></view><view class="field"><text class="label">户主</text><text class="value">{{household.headPersonName || '—'}}</text></view><view class="field"><text class="label">与户主关系</text><text class="value">{{household.relationship || '—'}}</text></view></view><view wx:else class="muted">暂无有效家庭户关系，或当前账号无权查看。</view></view>
</view></view>
