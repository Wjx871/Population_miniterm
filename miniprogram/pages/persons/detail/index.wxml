<view class="page person-detail-page">
  <loading-state wx:if="{{loading}}" text="正在加载人口档案…" />
  <error-state wx:elif="{{error}}" type="{{errorType}}" message="{{error}}" showRetry="{{errorType !== 'forbidden'}}" bindretry="load" />
  <block wx:else>
    <view class="person-summary summary-card">
      <view class="summary-avatar">
        <app-icon name="person" size="48" tone="deep" />
      </view>
      <view class="summary-main">
        <view class="summary-heading">
          <view class="summary-name">{{person.name}}</view>
          <status-tag text="{{person.statusDisplay}}" type="{{person.statusTone}}" size="small" />
        </view>
        <view class="summary-meta">
          <text>{{person.genderDisplay}}</text>
          <text>{{person.birthDateDisplay}}</text>
          <text wx:if="{{person.personTypeAvailable}}">{{person.personTypeDisplay}}</text>
        </view>
      </view>
    </view>

    <view class="detail-section card">
      <view class="section-heading">
        <view class="section-icon"><app-icon name="person" size="28" tone="primary" /></view>
        <view class="section-title">基础信息</view>
      </view>
      <view class="field"><text class="label">姓名</text><text class="value">{{person.name}}</text></view>
      <view class="field"><text class="label">性别</text><text class="value">{{person.genderDisplay}}</text></view>
      <view class="field"><text class="label">出生日期</text><text class="value">{{person.birthDateDisplay}}</text></view>
      <view class="field"><text class="label">民族</text><text class="value">{{person.ethnicityDisplay}}</text></view>
      <view wx:if="{{person.personTypeAvailable}}" class="field"><text class="label">人员类型</text><text class="value">{{person.personTypeDisplay}}</text></view>
    </view>

    <view class="detail-section card">
      <view class="section-heading">
        <view class="section-icon"><app-icon name="id-card" size="28" tone="primary" /></view>
        <view class="section-title">身份与联系方式</view>
      </view>
      <view class="field">
        <text class="label">身份证号</text>
        <sensitive-text class="value sensitive-value" value="{{person.idCardDisplay}}" expandable />
      </view>
      <view class="field">
        <text class="label">手机号</text>
        <sensitive-text class="value sensitive-value" value="{{person.phoneDisplay}}" />
      </view>
    </view>

    <view wx:if="{{residence}}" class="detail-section card">
      <view class="section-heading">
        <view class="section-icon"><app-icon name="location" size="28" tone="primary" /></view>
        <view class="section-title">居住信息</view>
      </view>
      <view class="field"><text class="label">当前地址</text><text class="value long-value">{{residence.addressDisplay}}</text></view>
      <view class="field"><text class="label">行政区划</text><text class="value long-value">{{residence.regionCodeDisplay}}</text></view>
      <view class="field"><text class="label">登记日期</text><text class="value">{{residence.registerDateDisplay}}</text></view>
      <view wx:if="{{residence.rawStatus}}" class="field"><text class="label">居住状态</text><status-tag text="{{residence.statusDisplay}}" type="{{residence.statusTone}}" size="small" /></view>
    </view>

    <view wx:if="{{currentPermit}}" class="detail-section card">
      <view class="section-heading"><view class="section-icon"><app-icon name="residence-permit" size="28" tone="primary" /></view><view class="section-title">当前居住证</view></view>
      <view class="field"><text class="label">证件编号</text><sensitive-text class="value" value="{{currentPermit.permitNoDisplay}}" /></view>
      <view class="field"><text class="label">签发区域</text><text class="value">{{currentPermit.issueRegionDisplay}}</text></view>
      <view class="field"><text class="label">有效期限</text><text class="value">{{currentPermit.validFromDisplay}} 至 {{currentPermit.validUntilDisplay}}</text></view>
      <view class="field"><text class="label">证件状态</text><status-tag text="{{currentPermit.statusDisplay}}" type="{{currentPermit.statusTone}}" size="small" /></view>
    </view>

    <view wx:if="{{migrationHistory.length}}" class="detail-section card">
      <view class="section-heading"><view class="section-icon"><app-icon name="history" size="28" tone="primary" /></view><view class="section-title">近期迁移记录</view></view>
      <view class="migration-summary" wx:for="{{migrationHistory}}" wx:key="migrationId"><view class="row-between"><text class="value">{{item.typeDisplay}} · {{item.businessDateDisplay}}</text><status-tag text="{{item.statusDisplay}}" type="{{item.statusTone}}" size="small" /></view><view class="muted">{{item.fromRegionDisplay}} 至 {{item.toRegionDisplay}}</view></view>
    </view>

    <view class="detail-section card">
      <view class="section-heading">
        <view class="section-icon"><app-icon name="household" size="28" tone="primary" /></view>
        <view class="section-title">当前家庭关系</view>
      </view>
      <loading-state wx:if="{{profileLoading}}" text="正在加载家庭关系…" />
      <error-state wx:elif="{{profileError}}" message="{{profileError}}" bindretry="retryProfile" />
      <empty-state
        wx:elif="{{profileLoaded && !household}}"
        title="暂无有效家庭关系"
        description="当前档案未登记有效家庭户关系"
      />
      <view wx:else class="household-relation" bindtap="openHousehold">
        <view class="field"><text class="label">家庭户编号</text><text class="value link">{{household.householdNoDisplay}}</text></view>
        <view class="field"><text class="label">户主</text><text class="value">{{household.headPersonNameDisplay}}</text></view>
        <view class="field"><text class="label">与户主关系</text><text class="value">{{household.relationshipDisplay}}</text></view>
        <view class="field"><text class="label">家庭地址</text><text class="value long-value">{{household.addressDisplay}}</text></view>
        <view class="relation-action"><text>查看家庭户档案</text><app-icon name="chevron-right" size="24" tone="primary" /></view>
      </view>
    </view>
  </block>
</view>
