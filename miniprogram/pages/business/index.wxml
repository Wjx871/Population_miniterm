<view class="page tab-page business-page">
  <view class="center-hero">
    <view class="hero-icon">
      <app-icon name="database" size="48" color="#FFFFFF" />
    </view>
    <view class="hero-copy">
      <view class="hero-title">业务中心</view>
      <view class="hero-description">人口与家庭户基础档案统一查询</view>
    </view>
  </view>

  <view class="page-section">
    <view class="section-header">
      <view>
        <view class="section-title">基础档案</view>
        <view class="section-caption">按当前账号权限展示</view>
      </view>
    </view>

    <empty-state
      wx:if="{{!entries.length}}"
      title="暂无可用业务"
      description="请联系系统管理员配置人口或家庭户查看权限"
    />
    <view wx:else class="center-list">
      <view
        class="center-entry list-card"
        wx:for="{{entries}}"
        wx:key="key"
        data-url="{{item.url}}"
        bindtap="open"
      >
        <view class="entry-icon">
          <app-icon name="{{item.icon}}" size="40" tone="primary" />
        </view>
        <view class="entry-copy">
          <view class="entry-title">{{item.title}}</view>
          <view class="entry-description">{{item.description}}</view>
        </view>
        <app-icon name="chevron-right" size="28" tone="muted" />
      </view>
    </view>
  </view>
</view>
