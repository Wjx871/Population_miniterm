.business-page {
  overflow-x: hidden;
}

.center-hero {
  display: flex;
  align-items: center;
  gap: 22rpx;
  margin-bottom: 34rpx;
  padding: 30rpx;
  color: #fff;
  background: linear-gradient(135deg, #0b2f6b, #1677ff);
  border-radius: 24rpx;
  box-shadow: 0 12rpx 30rpx rgba(11, 47, 107, 0.16);
}

.hero-icon,
.entry-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.hero-icon {
  width: 84rpx;
  height: 84rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  border-radius: 22rpx;
}

.hero-copy,
.entry-copy {
  min-width: 0;
  flex: 1;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 700;
}

.hero-description {
  margin-top: 6rpx;
  color: #e7f1ff;
  font-size: 23rpx;
}

.section-caption {
  margin-top: -10rpx;
  color: #8a94a6;
  font-size: 22rpx;
}

.center-entry {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-height: 132rpx;
}

.entry-icon {
  width: 72rpx;
  height: 72rpx;
  background: #eaf3ff;
  border-radius: 20rpx;
}

.entry-title {
  color: #17233d;
  font-size: 29rpx;
  font-weight: 650;
}

.entry-description {
  margin-top: 6rpx;
  color: #8a94a6;
  font-size: 22rpx;
}
