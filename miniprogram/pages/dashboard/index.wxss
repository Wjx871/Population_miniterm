.hero{display:flex;justify-content:space-between;align-items:center;background:linear-gradient(135deg,#1769aa,#2f8bd0);color:#fff}.hero .muted{color:#dceeff}.welcome{font-size:38rpx;font-weight:700;margin-bottom:10rpx}.avatar{width:90rpx;height:90rpx;line-height:90rpx;text-align:center;border-radius:50%;background:rgba(255,255,255,.2);font-size:38rpx}.stats{margin-bottom:38rpx}.functions{margin-top:36rpx}.entry{display:flex;align-items:center}.entry-icon{width:76rpx;height:76rpx;border-radius:18rpx;background:#eaf4fe;color:#1769aa;line-height:76rpx;text-align:center;font-weight:700}.entry-main{flex:1;margin-left:22rpx}.entry-desc{font-size:24rpx;margin-top:6rpx}.arrow{font-size:48rpx;color:#9aa8b7}
