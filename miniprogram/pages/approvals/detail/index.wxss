.approval-detail-page{overflow-x:hidden}.approval-summary{padding:30rpx;background:linear-gradient(145deg,#ffffff,#f4f8ff)}.business-name{min-width:0;color:#0b2f6b;font-size:36rpx;font-weight:700}.application-title{margin-top:8rpx;color:#344054;font-size:27rpx}.summary-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:18rpx;margin-top:24rpx}.summary-grid>view{min-width:0;padding:15rpx 16rpx;background:#f8faff;border-radius:12rpx}.summary-grid text{color:#7b8798;font-size:22rpx}.summary-grid view view{margin-top:3rpx;overflow-wrap:anywhere;font-size:24rpx}.decision-notice,.notice{margin-top:22rpx;padding:18rpx;color:#8a5a00;font-size:24rpx;background:#fff7e5;border-radius:12rpx}.material,.log{padding:20rpx 0;border-bottom:1rpx solid #edf1f5}.material:last-child,.log:last-child{border:0}.material-name{max-width:430rpx;font-weight:600}.meta{margin-top:8rpx}.preview{margin:14rpx 0 0 auto}.log view{margin-bottom:8rpx}.result-card{border-color:rgba(34,160,107,.22)}.decision{padding-bottom:0}.comment-count{margin-top:8rpx;text-align:right;color:#8a94a6;font-size:22rpx}.readonly-notice{text-align:center}
