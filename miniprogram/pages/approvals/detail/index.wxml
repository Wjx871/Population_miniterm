<view class="page approval-detail-page">
  <loading-state wx:if="{{loading}}" text="正在加载审批详情…" />
  <error-state wx:elif="{{error}}" message="{{error}}" bindretry="load"/>
  <view wx:else>
    <view class="summary-card approval-summary">
      <view class="row-between"><view class="business-name">{{application.businessTypeDisplay}}</view><status-tag text="{{detail.statusDisplay}}" type="{{detail.statusTone}}" /></view>
      <view class="application-title">{{application.title}}</view>
      <view class="summary-grid">
        <view><text>申请人</text><view>{{application.applicantName || '暂未登记'}}</view></view>
        <view><text>提交时间</text><view>{{application.submittedTimeDisplay}}</view></view>
        <view><text>申请编号</text><view>{{application.applicationNo}}</view></view>
        <view><text>审批编号</text><view>{{detail.approvalNo || '—'}}</view></view>
      </view>
      <view class="decision-notice">审批通过仅代表审核完成，相关业务仍需继续办理。</view>
    </view>
    <view class="section-card">
      <view class="section-title">申请说明</view>
      <view class="field"><text class="label">申请原因</text><text class="value">{{application.reason || '暂未登记'}}</text></view>
      <view class="field"><text class="label">补充说明</text><text class="value">{{application.remark || '无补充说明'}}</text></view>
    </view>
    <view class="section-card">
      <view class="section-title">业务信息</view>
      <view wx:if="{{professionalMessage}}" class="notice">{{professionalMessage}}</view>
      <view wx:for="{{professionalFields}}" wx:key="key" class="field"><text class="label">{{item.label}}</text><text class="value">{{item.value}}</text></view>
      <view wx:if="{{!professionalFields.length && !professionalMessage}}" class="muted">该申请暂无其他业务信息</view>
    </view>
    <view class="section-card">
      <view class="section-title">申请材料</view>
      <empty-state wx:if="{{!materials.length}}" title="无需额外材料" description="该业务当前没有需要审核的材料" />
      <view class="material" wx:for="{{materials}}" wx:key="materialId"><view class="row-between"><view class="material-name">{{item.materialName}}</view><status-tag text="{{item.verifyStatusDisplay}}" size="small" /></view><view class="muted meta">{{item.requiredDisplay}}</view><button wx:if="{{item.viewable}}" size="mini" class="ghost preview" data-id="{{item.materialId}}" data-type="{{item.contentType}}" bindtap="openMaterial">查看材料</button></view>
    </view>
    <view class="section-card">
      <view class="section-title">办理记录</view>
      <empty-state wx:if="{{!logs.length}}" title="暂无办理记录" description="后续处理情况将在这里显示" />
      <view class="log" wx:for="{{logs}}" wx:key="logId"><view>{{item.actionDisplay}}</view><view class="muted">{{item.timeDisplay}}</view><view>{{item.commentDisplay}}</view></view>
    </view>
    <view wx:if="{{detail.status!=='PENDING'}}" class="section-card result-card">
      <view class="section-title">审批结果</view>
      <view class="field"><text class="label">处理结果</text><text class="value">{{detail.statusDisplay}}</text></view>
      <view class="field"><text class="label">审批意见</text><text class="value">{{detail.decisionCommentDisplay}}</text></view>
      <view class="field"><text class="label">处理时间</text><text class="value">{{detail.decidedAtDisplay}}</text></view>
    </view>
    <view wx:if="{{canHandle && detail.status==='PENDING'}}" class="decision section-card">
      <view class="section-title">审批意见</view>
      <textarea class="textarea" maxlength="500" placeholder="通过意见可选；驳回时请填写具体原因" value="{{comment}}" bindinput="inputComment" />
      <view class="comment-count">{{comment.length}} / 500</view>
      <view class="safe-actions"><button class="danger-outline-button" data-action="reject" disabled="{{submitting}}" bindtap="decide">驳回申请</button><button class="primary" data-action="approve" loading="{{submitting}}" disabled="{{submitting}}" bindtap="decide">通过审批</button></view>
    </view>
    <view wx:elif="{{detail.status==='PENDING'}}" class="notice-card readonly-notice">当前账号可查看此事项，但没有审批操作权限。</view>
  </view>
</view>
