<view class="page"><view class="tabs card"><view class="tab {{tab==='pending'?'active':''}}" data-tab="pending" bindtap="switchTab">待审批</view><view class="tab {{tab==='processed'?'active':''}}" data-tab="processed" bindtap="switchTab">已审批</view></view><loading-state wx:if="{{loading}}"/><error-state wx:elif="{{error}}" message="{{error}}" bindretry="load"/><empty-state wx:elif="{{!records.length}}" text="{{tab==='pending'?'暂无待审批事项':'暂无已审批事项'}}"/><view class="card" wx:else wx:for="{{records}}" wx:key="approvalId" data-id="{{item.approvalId}}" bindtap="open"><view class="row-between"><view class="approval-no">{{item.approvalNo || item.applicationNo}}</view><status-tag text="{{item.statusDisplay}}"/></view><view class="approval-title">{{item.title}}</view><view class="muted line">{{item.businessTypeDisplay}}</view><view class="muted line">申请人：{{item.applicantName || '—'}}</view><view class="muted line">提交时间：{{item.submittedAtDisplay}}</view><view class="link open">进入审批 ›</view></view></view>
