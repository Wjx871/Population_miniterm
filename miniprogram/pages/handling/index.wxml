<view class="page tab-page handling-page">
  <view class="center-hero handling-hero">
    <view class="hero-icon">
      <app-icon name="approval" size="48" color="#FFFFFF" />
    </view>
    <view class="hero-copy">
      <view class="hero-title">办理中心</view>
      <view class="hero-description">申请记录与审批待办集中处理</view>
    </view>
  </view>

  <view wx:if="{{summaryLoading}}" class="summary-state card">
    <loading-state text="正在加载待审批数据…" />
  </view>
  <view wx:elif="{{summaryError}}" class="summary-state card">
    <error-state message="{{summaryError}}" bindretry="loadSummary" />
  </view>
  <view wx:elif="{{pendingSummary.available}}" class="pending-card card">
    <view class="pending-icon">
      <app-icon name="pending-approval" size="40" tone="warning" />
    </view>
    <view class="pending-copy">
      <view class="pending-label">当前待审批</view>
      <view class="pending-hint">数据来自现有工作台统计接口</view>
    </view>
    <view class="pending-value">{{pendingSummary.valueText}}</view>
  </view>

  <view class="page-section">
    <view class="section-header">
      <view>
        <view class="section-title">业务办理</view>
        <view class="section-caption">按当前账号权限展示</view>
      </view>
    </view>

    <empty-state
      wx:if="{{!entries.length}}"
      title="暂无可办理事项"
      description="请联系系统管理员配置申请或审批查看权限"
    />
    <view wx:else class="center-list">
      <view
        class="center-entry list-card"
        wx:for="{{entries}}"
        wx:key="key"
        data-url="{{item.url}}"
        bindtap="open"
      >
        <view class="entry-icon">
          <app-icon name="{{item.icon}}" size="40" tone="primary" />
        </view>
        <view class="entry-copy">
          <view class="entry-title">{{item.title}}</view>
          <view class="entry-description">{{item.description}}</view>
        </view>
        <app-icon name="chevron-right" size="28" tone="muted" />
      </view>
    </view>
  </view>
</view>
