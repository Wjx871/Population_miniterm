.household-detail-page { overflow-x: hidden; }
.household-summary { display: flex; align-items: center; gap: 22rpx; padding: 28rpx; background: linear-gradient(145deg, #fff, #f7fbff); }
.summary-icon, .section-icon, .member-avatar { display: flex; align-items: center; justify-content: center; flex-shrink: 0; background: #eaf3ff; }
.summary-icon { width: 88rpx; height: 88rpx; border-radius: 24rpx; }
.summary-main { min-width: 0; flex: 1; }
.summary-heading { display: flex; align-items: center; gap: 14rpx; min-width: 0; }
.summary-no { min-width: 0; flex: 1; color: #0b2f6b; font-size: 32rpx; font-weight: 700; overflow-wrap: anywhere; }
.summary-meta { display: flex; flex-wrap: wrap; gap: 8rpx 18rpx; margin-top: 9rpx; color: #123b7a; font-size: 22rpx; }
.summary-head { margin-top: 7rpx; color: #667085; font-size: 23rpx; }
.detail-section { padding-top: 24rpx; }
.section-heading { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.section-heading .section-title { margin: 0; font-size: 29rpx; }
.section-icon { width: 48rpx; height: 48rpx; border-radius: 14rpx; }
.field .long-value { min-width: 0; flex: 1; overflow-wrap: anywhere; word-break: break-word; white-space: normal; }
.members-section { margin-top: 32rpx; }
.members-header { margin: 0 4rpx 18rpx; align-items: flex-end; }
.members-header .section-title { margin: 0; }
.members-caption { margin-top: 3rpx; color: #8a94a6; font-size: 21rpx; }
.members-count { flex-shrink: 0; color: #667085; font-size: 22rpx; }
.member-card { display: flex; align-items: center; gap: 16rpx; }
.member-avatar { width: 66rpx; height: 66rpx; align-self: flex-start; border-radius: 18rpx; }
.member-content { min-width: 0; flex: 1; }
.member-heading { display: flex; align-items: center; flex-wrap: wrap; gap: 10rpx; min-width: 0; }
.member-name { min-width: 120rpx; flex: 1; color: #17233d; font-size: 29rpx; font-weight: 700; overflow-wrap: anywhere; }
.member-meta { display: flex; flex-wrap: wrap; gap: 8rpx 18rpx; margin-top: 8rpx; color: #123b7a; font-size: 22rpx; }
.member-line { margin-top: 7rpx; color: #667085; font-size: 21rpx; overflow-wrap: anywhere; }
