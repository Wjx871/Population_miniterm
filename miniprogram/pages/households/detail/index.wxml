<view class="page"><loading-state wx:if="{{loading}}"/><error-state wx:elif="{{error}}" message="{{error}}" bindretry="load"/><view wx:else><view class="card"><view class="row-between"><view class="title">{{household.householdNo}}</view><status-tag text="{{household.statusDisplay}}"/></view><view class="field"><text class="label">户主</text><text class="value">{{household.headPersonName}}</text></view><view class="field"><text class="label">家庭地址</text><sensitive-text class="value" value="{{household.addressDisplay}}" expandable/></view><view class="field"><text class="label">立户日期</text><text class="value">{{household.establishDateDisplay}}</text></view><view class="field"><text class="label">户籍类型</text><text class="value">{{household.householdType || '—'}}</text></view></view><view class="section-title">成员列表（{{members.length}}）</view><empty-state wx:if="{{!members.length}}" text="暂无有效成员"/><view class="card member" wx:for="{{members}}" wx:key="memberId" data-id="{{item.personId}}" bindtap="openPerson"><view class="row-between"><view class="member-name">{{item.personName}}</view><status-tag text="{{item.statusDisplay}}"/></view><view class="field"><text class="label">与户主关系</text><text class="value">{{item.relationshipDisplay}}</text></view><view class="field"><text class="label">身份证号</text><text class="value">{{item.idCardDisplay}}</text></view><view class="link open">查看人口档案 <app-icon name="chevron-right" size="24" /></view></view></view></view>
