<view class="page household-detail-page">
  <loading-state wx:if="{{loading}}" text="正在加载家庭户档案…" />
  <error-state wx:elif="{{error}}" type="{{errorType}}" message="{{error}}" showRetry="{{errorType !== 'forbidden'}}" bindretry="load" />
  <block wx:else>
    <view class="household-summary summary-card">
      <view class="summary-icon"><app-icon name="household" size="48" tone="deep" /></view>
      <view class="summary-main">
        <view class="summary-heading">
          <view class="summary-no">{{household.householdNo}}</view>
          <status-tag text="{{household.statusDisplay}}" type="{{household.statusTone}}" size="small" />
        </view>
        <view class="summary-meta"><text>{{household.householdTypeDisplay}}</text><text>{{household.activeMemberCountDisplay}}</text></view>
        <view class="summary-head">户主：{{household.headPersonName}}</view>
      </view>
    </view>

    <view class="detail-section card">
      <view class="section-heading"><view class="section-icon"><app-icon name="archive" size="28" tone="primary" /></view><view class="section-title">户籍基础信息</view></view>
      <view class="field"><text class="label">户籍编号</text><text class="value">{{household.householdNo}}</text></view>
      <view class="field"><text class="label">户主</text><text class="value">{{household.headPersonName}}</text></view>
      <view class="field"><text class="label">户口类型</text><text class="value">{{household.householdTypeDisplay}}</text></view>
      <view class="field"><text class="label">建档日期</text><text class="value">{{household.establishDateDisplay}}</text></view>
      <view class="field"><text class="label">有效成员</text><text class="value">{{household.activeMemberCountDisplay}}</text></view>
      <view class="field"><text class="label">当前状态</text><status-tag text="{{household.statusDisplay}}" type="{{household.statusTone}}" size="small" /></view>
    </view>

    <view class="detail-section card">
      <view class="section-heading"><view class="section-icon"><app-icon name="location" size="28" tone="primary" /></view><view class="section-title">地址信息</view></view>
      <view class="field"><text class="label">户籍地址</text><sensitive-text class="value long-value" value="{{household.addressDisplay}}" expandable /></view>
      <view class="field"><text class="label">行政区划</text><text class="value long-value">{{household.regionCodeDisplay}}</text></view>
    </view>

    <view class="members-section">
      <view class="members-header row-between">
        <view><view class="section-title">家庭成员</view><view class="members-caption">成员信息以当前有效档案为准</view></view>
        <text class="members-count">{{household.activeMemberCountDisplay}}</text>
      </view>
      <loading-state wx:if="{{membersLoading}}" text="正在加载家庭成员…" />
      <error-state wx:elif="{{membersError}}" message="{{membersError}}" bindretry="retryMembers" />
      <empty-state wx:elif="{{membersLoaded && !members.length}}" title="暂无家庭成员" description="当前家庭户未登记成员信息" />
      <block wx:else>
        <view class="member-card list-card" wx:for="{{members}}" wx:key="memberId" data-id="{{item.personId}}" bindtap="openPerson">
          <view class="member-avatar"><app-icon name="person" size="36" tone="primary" /></view>
          <view class="member-content">
            <view class="member-heading">
              <view class="member-name">{{item.personName}}</view>
              <status-tag wx:if="{{item.householdHead}}" text="户主" type="info" size="small" />
              <status-tag text="{{item.statusDisplay}}" type="{{item.statusTone}}" size="small" />
            </view>
            <view class="member-meta"><text>{{item.relationshipDisplay}}</text><text wx:if="{{item.genderAvailable}}">{{item.genderDisplay}}</text></view>
            <view class="member-line">身份证号：{{item.idCardDisplay}}</view>
            <view class="member-line">手机号：{{item.phoneDisplay}}</view>
          </view>
          <app-icon name="chevron-right" size="28" tone="muted" />
        </view>
      </block>
    </view>
  </block>
</view>
