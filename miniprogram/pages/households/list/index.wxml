<view class="page"><view class="card"><input class="input" placeholder="户籍编号" value="{{householdNo}}" bindinput="inputNo"/><input class="input" placeholder="户主姓名" value="{{headPersonName}}" bindinput="inputHead"/><view class="search-actions"><button class="primary" bindtap="search">查询</button><button class="ghost" bindtap="reset">重置</button></view></view><view class="row-between result-title"><view class="section-title">查询结果</view><text class="muted">共 {{total}} 户</text></view><loading-state wx:if="{{loading}}"/><error-state wx:elif="{{error}}" message="{{error}}" bindretry="search"/><empty-state wx:elif="{{!records.length}}" text="未查询到家庭户"/><view wx:else><view class="card" wx:for="{{records}}" wx:key="householdId" data-id="{{item.householdId}}" bindtap="open"><view class="row-between"><view class="household-no">{{item.householdNo}}</view><status-tag text="{{item.statusDisplay}}"/></view><view class="muted line">户主：{{item.headPersonName}}</view><view class="muted line ellipsis">地址：{{item.addressDisplay}}</view><view class="muted line">成员：{{item.activeMemberCount || 0}} 人</view><view class="link detail-link">查看详情 ›</view></view><loading-state wx:if="{{loadingMore}}" text="加载更多…"/><view wx:if="{{last && records.length}}" class="end">已加载全部家庭户</view></view></view>
