<view class="page"><loading-state wx:if="{{loading}}" text="正在加载居住登记…" /><error-state wx:elif="{{error}}" message="{{error}}" bindretry="load" /><block wx:else><view class="summary-card"><view class="section-heading"><app-icon name="person" size="40" tone="deep" /><view class="section-title">{{record.personName}}</view><status-tag text="{{record.statusDisplay}}" type="{{record.statusTone}}" size="small" /></view><view class="hint">登记号 {{record.registrationNoDisplay}}</view></view><view class="card"><view class="field"><text class="label">身份证号</text><sensitive-text class="value" value="{{record.identityNoDisplay}}" /></view><view class="field"><text class="label">手机号</text><sensitive-text class="value" value="{{record.phoneDisplay}}" /></view><view class="field"><text class="label">居住事由</text><text class="value">{{record.residenceReasonDisplay}}</text></view><view class="field"><text class="label">当前区域</text><text class="value">{{record.currentRegionDisplay}}</text></view><view class="field"><text class="label">当前地址</text><sensitive-text class="value" value="{{record.currentAddressDisplay}}" expandable /></view><view class="field"><text class="label">到达日期</text><text class="value">{{record.arrivalDateDisplay}}</text></view><view class="field"><text class="label">计划离开</text><text class="value">{{record.plannedLeaveDateDisplay}}</text></view></view></block></view>
