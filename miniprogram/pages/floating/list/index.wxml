<view class="page"><view class="hero"><view class="hero-icon"><app-icon name="population" size="48" color="#fff" /></view><view><view class="hero-title">流动人口查询</view><view class="hero-desc">查询居住登记与计划离开日期</view></view></view><view class="card filter-card"><view class="filter-stack"><view class="input-shell"><input class="filter-input" placeholder="姓名" value="{{personName}}" bindinput="inputName" /></view><view class="input-shell"><input class="filter-input" placeholder="身份证号" value="{{identityNo}}" bindinput="inputIdentity" /></view><picker range="{{statusOptions}}" range-key="label" value="{{statusIndex}}" bindchange="changeStatus"><view class="picker-shell row-between"><text>{{statusOptions[statusIndex].label}}</text><app-icon name="chevron-down" size="24" tone="muted" /></view></picker></view><view class="search-actions"><button class="primary" bindtap="search">查询</button><button class="ghost" bindtap="reset">重置</button></view></view><view class="result-head row-between"><view class="section-title">查询结果</view><text class="result-note">{{totalDisplay}} 条</text></view><loading-state wx:if="{{loading}}" text="正在加载流动人口…" /><error-state wx:elif="{{error}}" message="{{error}}" bindretry="search" /><empty-state wx:elif="{{!records.length}}" title="暂无流动人口记录" description="请调整查询条件后重试" /><block wx:else><view class="business-item list-card" wx:for="{{records}}" wx:key="floatingId" data-id="{{item.floatingId}}" bindtap="open"><view class="item-icon"><app-icon name="person" size="40" tone="primary" /></view><view class="item-main"><view class="row-between"><view class="item-title">{{item.personName}}</view><status-tag text="{{item.statusDisplay}}" type="{{item.statusTone}}" size="small" /></view><view class="item-line">身份证号：{{item.identityNoDisplay}}</view><view class="item-meta"><text>{{item.residenceReasonDisplay}}</text><text>到达 {{item.arrivalDateDisplay}}</text></view></view><app-icon name="chevron-right" size="28" tone="muted" /></view><loading-state wx:if="{{loadingMore}}" text="加载更多…" /><view wx:if="{{last && records.length}}" class="end">已加载全部记录</view></block></view>
