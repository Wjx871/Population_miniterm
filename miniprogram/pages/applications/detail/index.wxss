.application-detail-page{overflow-x:hidden}.application-summary{padding:30rpx;background:linear-gradient(145deg,#ffffff,#f4f8ff)}.summary-top{align-items:center}.business-name{min-width:0;color:#0b2f6b;font-size:36rpx;font-weight:700}.application-title{margin-top:8rpx;color:#344054;font-size:27rpx}.summary-meta{margin-top:18rpx;color:#667085;font-size:23rpx}.status-guidance{margin-top:22rpx;padding:18rpx 20rpx;color:#123b7a;font-size:25rpx;background:#eaf3ff;border-radius:16rpx}.notice{padding:18rpx;background:#fff7e5;color:#8a5a00;border-radius:12rpx}.progress-item{position:relative;display:flex;gap:18rpx;padding-bottom:30rpx}.progress-item:last-child{padding-bottom:0}.progress-item::before{content:"";position:absolute;left:9rpx;top:22rpx;bottom:0;width:2rpx;background:#dce5f1}.progress-item:last-child::before{display:none}.progress-marker{z-index:1;width:20rpx;height:20rpx;margin-top:7rpx;flex-shrink:0;background:#c7d0dc;border:5rpx solid #fff;border-radius:50%;box-shadow:0 0 0 2rpx #c7d0dc}.progress-item--done .progress-marker{background:#22a06b;box-shadow:0 0 0 2rpx #22a06b}.progress-item--current .progress-marker{background:#1677ff;box-shadow:0 0 0 2rpx #1677ff}.progress-content{min-width:0;flex:1}.progress-title{font-weight:650}.progress-time{color:#8a94a6;font-size:22rpx}.progress-result{margin-top:5rpx;color:#667085;font-size:24rpx}.material{padding:20rpx 0;border-bottom:1rpx solid #edf1f5}.material:last-child{border:0}.material-name{max-width:430rpx;font-weight:600}.meta{margin-top:8rpx}.preview{margin:16rpx 0 0 auto}.approval-result{border-color:rgba(34,160,107,.22)}.timeline{display:flex;gap:18rpx;padding-bottom:28rpx}.dot{width:18rpx;height:18rpx;margin-top:10rpx;flex-shrink:0;background:#1677ff;border-radius:50%}.timeline-main{padding-left:20rpx;flex:1;border-left:2rpx solid #dce7f1}.small{margin-top:6rpx;font-size:24rpx}.comment{margin-top:10rpx;color:#344054}
