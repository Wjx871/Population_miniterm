<view class="page application-list-page">
  <view class="page-intro">
    <view class="page-title">我的申请</view>
    <view class="page-description">查看业务申请的审核结果与办理进度</view>
  </view>

  <view class="filter-card card">
    <view class="filter-label">查找申请</view>
    <input class="input" placeholder="输入申请编号" value="{{applicationNo}}" bindinput="inputNo" />
    <picker range="{{statusOptions}}" range-key="label" value="{{statusIndex}}" bindchange="changeStatus">
      <view class="picker">
        <text>申请状态：{{statusOptions[statusIndex].label}}</text>
        <app-icon name="chevron-down" size="24" tone="muted" />
      </view>
    </picker>
    <view class="search-actions">
      <button class="primary" bindtap="search">查询申请</button>
      <button class="ghost" bindtap="reset">清除条件</button>
    </view>
  </view>

  <view class="row-between result-title">
    <view>
      <view class="section-title">申请记录</view>
      <view class="result-caption">按提交时间查看办理情况</view>
    </view>
    <text class="result-count">{{total}} 条</text>
  </view>

  <loading-state wx:if="{{loading}}" text="正在加载申请记录…" />
  <error-state wx:elif="{{error}}" message="{{error}}" bindretry="search" />
  <empty-state
    wx:elif="{{!records.length}}"
    title="{{applicationNo || statusIndex ? '未找到符合条件的申请' : '暂无申请记录'}}"
    description="{{applicationNo || statusIndex ? '请清除筛选条件后重新查看' : '当前账号还没有提交过业务申请'}}"
    action-text="{{applicationNo || statusIndex ? '清除筛选条件' : ''}}"
    bindaction="reset"
  />
  <view wx:else class="application-list">
    <view class="application-card list-card" wx:for="{{records}}" wx:key="applicationId" data-id="{{item.applicationId}}" bindtap="open">
      <view class="row-between card-heading">
        <view class="business-name">{{item.businessTypeDisplay}}</view>
        <status-tag text="{{item.statusDisplay}}" type="{{item.statusTone}}" size="small" />
      </view>
      <view class="application-title">{{item.title}}</view>
      <view class="application-meta">
        <text>申请编号 {{item.applicationNo}}</text>
        <text>提交时间 {{item.submittedTimeDisplay}}</text>
      </view>
      <view class="next-step">{{item.nextStepDisplay}}</view>
      <view class="card-action">
        <text>查看办理进度</text>
        <app-icon name="chevron-right" size="24" tone="primary" />
      </view>
    </view>
    <loading-state wx:if="{{loadingMore}}" text="正在加载更多…" />
    <view wx:if="{{last && records.length}}" class="end">已显示全部申请</view>
  </view>
</view>
