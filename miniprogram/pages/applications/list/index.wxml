<view class="page"><view class="card"><input class="input" placeholder="申请编号" value="{{applicationNo}}" bindinput="inputNo"/><picker range="{{statusOptions}}" range-key="label" value="{{statusIndex}}" bindchange="changeStatus"><view class="picker">状态：{{statusOptions[statusIndex].label}} <text>⌄</text></view></picker><view class="search-actions"><button class="primary" bindtap="search">查询</button><button class="ghost" bindtap="reset">重置</button></view></view><view class="row-between result-title"><view class="section-title">申请记录</view><text class="muted">共 {{total}} 条</text></view><loading-state wx:if="{{loading}}"/><error-state wx:elif="{{error}}" message="{{error}}" bindretry="search"/><empty-state wx:elif="{{!records.length}}" text="暂无可查看的申请"/><view wx:else><view class="card" wx:for="{{records}}" wx:key="applicationId" data-id="{{item.applicationId}}" bindtap="open"><view class="row-between"><view class="application-no">{{item.applicationNo}}</view><status-tag text="{{item.statusDisplay}}"/></view><view class="app-title">{{item.title}}</view><view class="muted line">{{item.businessTypeDisplay}}</view><view class="muted line">创建时间：{{item.createdAtDisplay}}</view><view class="link detail-link">查看详情 ›</view></view><loading-state wx:if="{{loadingMore}}" text="加载更多…"/><view wx:if="{{last && records.length}}" class="end">已加载全部申请</view></view></view>
