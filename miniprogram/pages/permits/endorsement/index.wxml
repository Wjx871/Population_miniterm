<view class="page">
  <view class="step-line"><view class="step {{step >= 1 ? 'active' : ''}}">1 选择证件</view><view class="step {{step >= 2 ? 'active' : ''}}">2 填写申请</view><view class="step {{step >= 3 ? 'active' : ''}}">3 上传并提交</view></view>
  <loading-state wx:if="{{loading}}" text="正在加载可签注证件…" />
  <error-state wx:elif="{{error}}" message="{{error}}" bindretry="loadPermits" />
  <block wx:elif="{{step === 1}}">
    <view class="notice-card">移动端仅发起申请并跟踪进度；审批后的专业签注执行在 Web 端完成。</view>
    <empty-state wx:if="{{!permits.length}}" title="暂无可签注证件" description="仅有效且进入签注窗口的证件可办理" />
    <block wx:else>
      <view class="select-card {{selected && selected.permitId === item.permitId ? 'active' : ''}}" wx:for="{{permits}}" wx:key="permitId" data-id="{{item.permitId}}" bindtap="select"><app-icon name="residence-permit" size="40" tone="primary" /><view class="item-main"><view class="item-title">{{item.personName}}</view><view class="item-line">{{item.permitNoDisplay}} · 有效至 {{item.validUntilDisplay}}</view></view><app-icon name="{{selected && selected.permitId === item.permitId ? 'checkbox-checked' : 'checkbox'}}" size="28" tone="primary" /></view>
    </block>
    <view wx:if="{{permits.length}}" class="safe-actions"><button class="primary" bindtap="next">下一步</button></view>
  </block>
  <block wx:elif="{{step === 2}}">
    <view class="card"><view class="section-title">申请信息</view><text class="form-label">申请标题</text><input class="input" value="{{title}}" bindinput="inputTitle" /><text class="form-label">居住事由</text><picker range="{{basisOptions}}" range-key="label" value="{{basisIndex}}" bindchange="changeBasis"><view class="picker-shell row-between"><text>{{basisOptions[basisIndex].label}}</text><app-icon name="chevron-down" size="24" tone="muted" /></view></picker><text class="form-label">申请原因</text><textarea class="textarea" placeholder="请说明持续居住及签注原因" value="{{reason}}" bindinput="inputReason" /><text class="form-label">补充说明（选填）</text><textarea class="textarea" placeholder="可填写需要审批人员关注的信息" value="{{remark}}" bindinput="inputRemark" /></view>
    <view class="safe-actions"><button class="ghost" bindtap="previous">返回选证</button><button class="primary" loading="{{creating}}" disabled="{{creating}}" bindtap="createApplication">创建申请</button></view>
  </block>
  <block wx:else>
    <view class="notice-card">申请 {{applicationNo}} 已保存为草稿。两项必需材料上传完成后才可提交。</view>
    <view class="card"><view class="section-title">必需材料</view><view class="material-row" wx:for="{{materials}}" wx:key="type"><app-icon name="{{item.uploaded ? 'check-circle' : 'material'}}" size="32" tone="{{item.uploaded ? 'success' : 'primary'}}" /><view class="material-main"><view class="material-name">{{item.name}}</view><view class="material-state">{{item.uploaded ? item.filename : '支持图片、PDF 等系统允许的文件'}}</view></view><button class="small-button" data-index="{{index}}" loading="{{item.uploading}}" disabled="{{item.uploading}}" bindtap="chooseMaterial">{{item.uploaded ? '重新上传' : '选择文件'}}</button></view></view>
    <view class="safe-actions"><button class="ghost" bindtap="openApplication">稍后处理</button><button class="primary" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submit">提交审批</button></view>
  </block>
</view>
