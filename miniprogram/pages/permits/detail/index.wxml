<view class="page"><loading-state wx:if="{{loading}}" text="正在加载居住证…" /><error-state wx:elif="{{error}}" message="{{error}}" bindretry="load" /><block wx:else><view class="summary-card"><view class="section-heading"><app-icon name="residence-permit" size="40" tone="deep" /><view class="section-title">{{permit.personName}}</view><status-tag text="{{permit.statusDisplay}}" type="{{permit.statusTone}}" size="small" /></view><view class="hint">证件号 {{permit.permitNoDisplay}}</view></view><view class="card"><view class="field"><text class="label">身份证号</text><sensitive-text class="value" value="{{permit.identityNoDisplay}}" /></view><view class="field"><text class="label">签发区域</text><text class="value">{{permit.regionDisplay}}</text></view><view class="field"><text class="label">当前地址</text><sensitive-text class="value" value="{{permit.currentAddressDisplay}}" expandable /></view><view class="field"><text class="label">有效期起</text><text class="value">{{permit.validFromDisplay}}</text></view><view class="field"><text class="label">有效期止</text><text class="value">{{permit.validUntilDisplay}}</text></view></view><view wx:if="{{canViewApplication}}" class="card" bindtap="openApplication"><view class="row-between"><view><view class="item-title">查看来源申请</view><view class="hint">查看申请进度和最终办理状态</view></view><app-icon name="chevron-right" size="28" tone="primary" /></view></view><view wx:if="{{canApply}}" class="safe-actions"><button class="primary" bindtap="apply">发起签注申请</button></view></block></view>
