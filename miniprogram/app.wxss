/*
 * Population mobile design system
 * Primary #1677FF | Navy #123B7A / #0B2F6B | Canvas #F3F7FC
 * Success #22A06B | Warning #F59E0B | Danger #E5484D
 */

page {
  min-height: 100%;
  background: #f3f7fc;
  color: #17233d;
  font-size: 28rpx;
  line-height: 1.55;
  box-sizing: border-box;
}

view,
text,
input,
button,
textarea,
picker {
  box-sizing: border-box;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(40rpx + env(safe-area-inset-bottom));
}

.page-content {
  width: 100%;
  max-width: 100%;
}

.tab-page {
  padding-bottom: calc(148rpx + env(safe-area-inset-bottom));
}

.tab-page-content {
  width: 100%;
}

.tab-safe-bottom {
  height: calc(124rpx + env(safe-area-inset-bottom));
}

.page-section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.title,
.page-title {
  margin-bottom: 20rpx;
  color: #0b2f6b;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.35;
}

.section-title {
  margin-bottom: 18rpx;
  color: #123b7a;
  font-size: 32rpx;
  font-weight: 650;
  line-height: 1.4;
}

.section-header .section-title {
  margin-bottom: 0;
}

.section-extra {
  flex-shrink: 0;
  color: #667085;
  font-size: 24rpx;
}

.card,
.summary-card,
.section-card,
.list-card,
.form-card {
  width: 100%;
  margin-bottom: 22rpx;
  padding: 28rpx;
  overflow: hidden;
  background: #fff;
  border: 1rpx solid rgba(229, 234, 242, 0.9);
  border-radius: 22rpx;
  box-shadow: 0 8rpx 24rpx rgba(22, 51, 92, 0.06);
}

.summary-card {
  border-color: rgba(22, 119, 255, 0.12);
}

.section-card {
  padding-top: 24rpx;
}

.list-card {
  padding: 24rpx 26rpx;
  transition: background-color 120ms ease, transform 120ms ease;
}

.list-card:active {
  background: #f8fbff;
  transform: scale(0.995);
}

.notice-card {
  margin-bottom: 22rpx;
  padding: 20rpx 22rpx;
  color: #123b7a;
  font-size: 24rpx;
  background: #edf5ff;
  border: 1rpx solid rgba(22, 119, 255, 0.14);
  border-radius: 16rpx;
}

.field,
.field-row {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  min-width: 0;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #e5eaf2;
}

.field:last-child,
.field-row:last-child {
  border-bottom: 0;
}

.label,
.field-label {
  width: 190rpx;
  flex-shrink: 0;
  color: #667085;
  font-size: 26rpx;
}

.value,
.field-value {
  min-width: 0;
  flex: 1;
  color: #17233d;
  overflow-wrap: anywhere;
  word-break: break-word;
}

.divider {
  width: 100%;
  height: 1rpx;
  margin: 20rpx 0;
  background: #e5eaf2;
}

.status-dot {
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  margin-right: 10rpx;
  background: #98a2b3;
  border-radius: 999rpx;
  vertical-align: 2rpx;
}

.status-dot.success {
  background: #22a06b;
}

.status-dot.warning {
  background: #f59e0b;
}

.status-dot.danger {
  background: #e5484d;
}

.muted,
.muted-text {
  color: #667085;
}

.weak-text {
  color: #8a94a6;
}

.text-success {
  color: #22a06b;
}

.text-warning {
  color: #b76e00;
}

.text-danger,
.required {
  color: #e5484d;
}

.primary,
.primary-button,
.secondary-button,
.danger-outline-button,
.ghost {
  min-height: 80rpx;
  padding: 0 28rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 80rpx;
}

.primary,
.primary-button {
  color: #fff !important;
  background: #1677ff !important;
}

.primary:active,
.primary-button:active {
  background: #0f68e8 !important;
}

.secondary-button,
.ghost {
  color: #1677ff !important;
  background: #fff !important;
  border: 1rpx solid rgba(22, 119, 255, 0.55);
}

.danger-outline-button {
  color: #e5484d !important;
  background: #fff !important;
  border: 1rpx solid rgba(229, 72, 77, 0.65);
}

.danger {
  color: #fff !important;
  background: #e5484d !important;
  border-radius: 16rpx;
}

button[disabled] {
  color: #fff !important;
  background: #98a2b3 !important;
  opacity: 0.72;
}

.input,
.textarea {
  width: 100%;
  color: #17233d;
  background: #f8faff;
  border: 1rpx solid #e5eaf2;
  border-radius: 16rpx;
}

.input {
  height: 84rpx;
  margin-bottom: 20rpx;
  padding: 0 22rpx;
}

.textarea {
  min-height: 150rpx;
  padding: 20rpx;
}

.input:focus,
.textarea:focus {
  border-color: #1677ff;
}

.search-actions {
  display: flex;
  gap: 16rpx;
}

.search-actions button {
  min-width: 0;
  flex: 1;
}

.safe-actions,
.safe-bottom {
  position: sticky;
  bottom: 0;
  z-index: 5;
  display: flex;
  gap: 16rpx;
  padding: 18rpx 0 calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(243, 247, 252, 0.96);
}

.safe-actions button,
.safe-bottom button {
  min-width: 0;
  flex: 1;
}

.link {
  color: #1677ff;
}

.ellipsis {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-width: 0;
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.stat {
  min-width: 0;
  padding: 22rpx;
  background: #edf5ff;
  border-radius: 16rpx;
}

.stat-number {
  color: #1677ff;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.25;
}
