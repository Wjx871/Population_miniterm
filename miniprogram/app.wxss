page{background:#f4f7fb;color:#1f2d3d;font-size:28rpx;box-sizing:border-box}view,text,input,button,textarea{box-sizing:border-box}.page{min-height:100vh;padding:24rpx 24rpx calc(40rpx + env(safe-area-inset-bottom))}.card{background:#fff;border-radius:18rpx;padding:28rpx;margin-bottom:22rpx;box-shadow:0 6rpx 24rpx rgba(27,76,122,.07)}.title{font-size:36rpx;font-weight:700;margin-bottom:20rpx}.section-title{font-size:30rpx;font-weight:600;margin-bottom:18rpx}.muted{color:#7a8898}.field{display:flex;padding:14rpx 0;border-bottom:1rpx solid #edf1f5;gap:20rpx}.field:last-child{border-bottom:0}.label{width:190rpx;color:#667587;flex-shrink:0}.value{flex:1;word-break:break-all}.primary{background:#1769aa!important;color:#fff!important;border-radius:12rpx}.danger{background:#d64545!important;color:#fff!important}.ghost{background:#fff!important;color:#1769aa!important;border:1rpx solid #1769aa}.input{height:84rpx;background:#f7f9fc;border:1rpx solid #dce4ec;border-radius:12rpx;padding:0 22rpx;margin-bottom:20rpx}.search-actions{display:flex;gap:16rpx}.search-actions button{flex:1}.safe-actions{position:sticky;bottom:0;background:rgba(244,247,251,.96);padding:18rpx 0 calc(18rpx + env(safe-area-inset-bottom));display:flex;gap:16rpx;z-index:5}.safe-actions button{flex:1}.link{color:#1769aa}.ellipsis{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.row-between{display:flex;align-items:center;justify-content:space-between;gap:16rpx}.grid{display:grid;grid-template-columns:1fr 1fr;gap:18rpx}.stat{background:#edf5fd;border-radius:14rpx;padding:22rpx}.stat-number{font-size:42rpx;color:#1769aa;font-weight:700}.required{color:#d64545}.textarea{width:100%;min-height:150rpx;background:#f7f9fc;border:1rpx solid #dce4ec;border-radius:12rpx;padding:20rpx}
