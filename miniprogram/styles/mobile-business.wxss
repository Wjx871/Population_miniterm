.hero { display:flex; align-items:center; gap:20rpx; margin-bottom:22rpx; padding:26rpx; color:#fff; background:linear-gradient(135deg,#0b2f6b,#1677ff); border-radius:22rpx; }
.hero-icon,.item-icon { display:flex; align-items:center; justify-content:center; flex-shrink:0; border-radius:18rpx; }
.hero-icon { width:76rpx; height:76rpx; background:rgba(255,255,255,.14); }
.hero-title { font-size:34rpx; font-weight:700; }
.hero-desc { margin-top:4rpx; color:#e7f1ff; font-size:23rpx; }
.filter-card { padding:24rpx; }
.filter-stack { display:flex; flex-direction:column; gap:14rpx; }
.input-shell,.picker-shell { display:flex; align-items:center; min-height:80rpx; padding:0 20rpx; background:#f8faff; border:1rpx solid #e5eaf2; border-radius:15rpx; }
.filter-input { min-width:0; height:78rpx; flex:1; }
.result-head { margin:28rpx 4rpx 16rpx; }
.result-note { color:#8a94a6; font-size:22rpx; }
.business-item { display:flex; align-items:flex-start; gap:18rpx; }
.item-icon { width:68rpx; height:68rpx; background:#eaf3ff; }
.item-main { min-width:0; flex:1; }
.item-title { color:#17233d; font-size:30rpx; font-weight:700; }
.item-meta { display:flex; flex-wrap:wrap; gap:8rpx 16rpx; margin-top:7rpx; color:#667085; font-size:22rpx; }
.item-line { margin-top:7rpx; color:#667085; font-size:22rpx; overflow-wrap:anywhere; }
.end { padding:22rpx; color:#8a94a6; font-size:22rpx; text-align:center; }
.section-heading { display:flex; align-items:center; gap:12rpx; margin-bottom:8rpx; }
.section-heading .section-title { margin:0; }
.hint { color:#667085; font-size:23rpx; }
.form-label { display:block; margin:18rpx 0 8rpx; color:#344054; font-size:25rpx; font-weight:600; }
.select-card { display:flex; align-items:center; gap:16rpx; padding:20rpx; border:1rpx solid #dce8f8; border-radius:16rpx; }
.select-card.active { background:#edf5ff; border-color:#1677ff; }
.material-row { display:flex; align-items:center; gap:14rpx; padding:18rpx 0; border-bottom:1rpx solid #e5eaf2; }
.material-row:last-child { border-bottom:0; }
.material-main { min-width:0; flex:1; }
.material-name { font-weight:600; }
.material-state { color:#667085; font-size:22rpx; }
.small-button { min-height:62rpx; padding:0 20rpx; color:#1677ff; background:#edf5ff; border-radius:12rpx; font-size:24rpx; line-height:62rpx; }
.step-line { display:flex; justify-content:space-between; gap:8rpx; margin-bottom:22rpx; }
.step { flex:1; color:#98a2b3; font-size:22rpx; text-align:center; }
.step.active { color:#1677ff; font-weight:700; }
