<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wjx871.population.approval.ApprovalRequestMapper">
 <resultMap id="map" type="com.wjx871.population.approval.ApprovalRequest"><id property="approvalId" column="approval_id"/><result property="approvalNo" column="approval_no"/><result property="applicationId" column="application_id"/><result property="status" column="status"/><result property="currentApproverId" column="current_approver_id"/><result property="currentDepartmentId" column="current_department_id"/><result property="currentRegionCode" column="current_region_code"/><result property="submittedBy" column="submitted_by"/><result property="submittedAt" column="submitted_at"/><result property="decidedBy" column="decided_by"/><result property="decidedAt" column="decided_at"/><result property="decisionComment" column="decision_comment"/><result property="version" column="version"/><result property="createdAt" column="created_at"/><result property="updatedAt" column="updated_at"/></resultMap>
 <sql id="cols">approval_id,approval_no,application_id,status,current_approver_id,current_department_id,current_region_code,submitted_by,submitted_at,decided_by,decided_at,decision_comment,version,created_at,updated_at</sql>
 <insert id="insert" useGeneratedKeys="true" keyProperty="approvalId">INSERT INTO sys_approval_request(approval_no,application_id,status,current_approver_id,current_department_id,current_region_code,submitted_by,submitted_at,version) VALUES(#{approvalNo},#{applicationId},#{status},#{currentApproverId},#{currentDepartmentId},#{currentRegionCode},#{submittedBy},#{submittedAt},#{version})</insert>
 <select id="selectById" resultMap="map">SELECT <include refid="cols"/> FROM sys_approval_request WHERE approval_id=#{id}</select>
 <select id="selectByApplicationId" resultMap="map">SELECT <include refid="cols"/> FROM sys_approval_request WHERE application_id=#{id}</select>
 <update id="decide">UPDATE sys_approval_request SET status=#{to},decided_by=#{userId},decided_at=CURRENT_TIMESTAMP,decision_comment=#{comment},version=version+1,updated_at=CURRENT_TIMESTAMP WHERE approval_id=#{id} AND status=#{from} AND version=#{version}</update>
 <!-- 仅 PENDING 或 CANCELLED 的旧审批单可被申请人在 RETURNED 状态下重新提交并重置为 PENDING；行唯一由 application_id 保证。 -->
 <update id="resetForResubmit">UPDATE sys_approval_request SET status='PENDING',decided_by=NULL,decided_at=NULL,decision_comment=NULL,version=0,submitted_by=#{userId},submitted_at=#{submittedAt},updated_at=CURRENT_TIMESTAMP WHERE application_id=#{applicationId} AND status IN ('PENDING','APPROVED','REJECTED','CANCELLED')</update>
 <select id="selectByStatus" resultType="com.wjx871.population.approval.ApprovalSummary">SELECT r.approval_id,r.approval_no,r.application_id,a.application_no,a.title,a.business_type,r.status,r.submitted_by,u.real_name applicant_name,r.submitted_at,r.version FROM sys_approval_request r JOIN business_application a ON a.application_id=r.application_id JOIN sys_user u ON u.user_id=a.applicant_user_id
  <where><choose><when test="pending">r.status='PENDING'</when><otherwise>r.status!='PENDING'</otherwise></choose>
   <choose><when test="scope.dataScope.name() == 'DEPARTMENT'">AND a.applicant_department_id=#{scope.departmentId}</when><when test="scope.dataScope.name() == 'REGION'">AND a.applicant_region_code=#{scope.regionCode}</when><when test="scope.dataScope.name() == 'SELF'">AND a.applicant_user_id=#{scope.userId}</when></choose>
  </where> ORDER BY r.submitted_at DESC</select>
</mapper>
