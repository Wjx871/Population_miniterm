<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wjx871.population.application.BusinessApplicationMapper">
  <resultMap id="map" type="com.wjx871.population.application.BusinessApplication">
    <id property="applicationId" column="application_id"/><result property="applicationNo" column="application_no"/>
    <result property="businessType" column="business_type"/><result property="title" column="title"/>
    <result property="applicantUserId" column="applicant_user_id"/><result property="applicantName" column="applicant_name"/>
    <result property="applicantDepartmentId" column="applicant_department_id"/><result property="applicantRegionCode" column="applicant_region_code"/>
    <result property="targetPersonId" column="target_person_id"/><result property="targetHouseholdId" column="target_household_id"/>
    <result property="status" column="status"/><result property="reason" column="reason"/><result property="remark" column="remark"/>
    <result property="submittedAt" column="submitted_at"/><result property="completedAt" column="completed_at"/>
    <result property="version" column="version"/><result property="createdAt" column="created_at"/><result property="updatedAt" column="updated_at"/>
  </resultMap>
  <sql id="columns">a.application_id,a.application_no,a.business_type,a.title,a.applicant_user_id,u.real_name applicant_name,
    a.applicant_department_id,a.applicant_region_code,a.target_person_id,a.target_household_id,a.status,a.reason,a.remark,
    a.submitted_at,a.completed_at,a.version,a.created_at,a.updated_at</sql>
  <select id="selectById" resultMap="map">SELECT <include refid="columns"/> FROM business_application a JOIN sys_user u ON u.user_id=a.applicant_user_id WHERE a.application_id=#{applicationId}</select>
  <sql id="filters"><where>
    <if test="applicationNo != null">AND a.application_no LIKE CONCAT('%',#{applicationNo},'%')</if>
    <if test="businessType != null">AND a.business_type=#{businessType}</if><if test="status != null">AND a.status=#{status}</if>
    <if test="applicantName != null">AND u.real_name LIKE CONCAT('%',#{applicantName},'%')</if>
    <if test="createdFrom != null">AND a.created_at &gt;= #{createdFrom}</if><if test="createdTo != null">AND a.created_at &lt;= #{createdTo}</if>
    <choose><when test="!approvalViewer">AND a.applicant_user_id=#{scope.userId}</when>
      <when test="scope.dataScope.name() == 'DEPARTMENT'">AND a.applicant_department_id=#{scope.departmentId}</when>
      <when test="scope.dataScope.name() == 'REGION'">AND a.applicant_region_code=#{scope.regionCode}</when>
      <when test="scope.dataScope.name() == 'SELF'">AND a.applicant_user_id=#{scope.userId}</when></choose>
  </where></sql>
  <select id="countByQuery" resultType="long">SELECT COUNT(*) FROM business_application a JOIN sys_user u ON u.user_id=a.applicant_user_id <include refid="filters"/></select>
  <select id="selectByQuery" resultMap="map">SELECT <include refid="columns"/> FROM business_application a JOIN sys_user u ON u.user_id=a.applicant_user_id <include refid="filters"/> ORDER BY a.created_at DESC LIMIT #{limit} OFFSET #{offset}</select>
  <insert id="insert" parameterType="com.wjx871.population.application.BusinessApplication" useGeneratedKeys="true" keyProperty="applicationId">
    INSERT INTO business_application(application_no,business_type,title,applicant_user_id,applicant_department_id,applicant_region_code,target_person_id,target_household_id,status,reason,remark,version)
    VALUES(#{applicationNo},#{businessType},#{title},#{applicantUserId},#{applicantDepartmentId},#{applicantRegionCode},#{targetPersonId},#{targetHouseholdId},#{status},#{reason},#{remark},#{version})
  </insert>
  <update id="updateDraft">UPDATE business_application SET business_type=#{application.businessType},title=#{application.title},target_person_id=#{application.targetPersonId},target_household_id=#{application.targetHouseholdId},reason=#{application.reason},remark=#{application.remark},version=version+1,updated_at=CURRENT_TIMESTAMP WHERE application_id=#{application.applicationId} AND status='DRAFT' AND version=#{expectedVersion}</update>
  <update id="updateStatus">UPDATE business_application SET status=#{toStatus},version=version+1,updated_at=CURRENT_TIMESTAMP,
    submitted_at=CASE WHEN #{toStatus}='UNDER_REVIEW' THEN CURRENT_TIMESTAMP ELSE submitted_at END,
    completed_at=CASE WHEN #{toStatus} IN ('APPROVED','REJECTED') THEN CURRENT_TIMESTAMP ELSE completed_at END
    WHERE application_id=#{applicationId} AND status=#{fromStatus} AND version=#{expectedVersion}</update>
</mapper>
