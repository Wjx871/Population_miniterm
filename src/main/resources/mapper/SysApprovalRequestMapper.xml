<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.population.mapper.SysApprovalRequestMapper">

    <select id="selectByIdForUpdate" resultType="com.example.population.entity.SysApprovalRequest">
        SELECT * FROM sys_approval_request WHERE approval_id = #{id} LIMIT 1 FOR UPDATE
    </select>

</mapper>
