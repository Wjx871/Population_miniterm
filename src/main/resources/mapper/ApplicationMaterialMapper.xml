<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wjx871.population.material.ApplicationMaterialMapper">
 <resultMap id="map" type="com.wjx871.population.material.ApplicationMaterial"><id property="materialId" column="material_id"/><result property="applicationId" column="application_id"/><result property="materialType" column="material_type"/><result property="materialName" column="material_name"/><result property="originalFilename" column="original_filename"/><result property="storedFilename" column="stored_filename"/><result property="storagePath" column="storage_path"/><result property="contentType" column="content_type"/><result property="fileSize" column="file_size"/><result property="fileSha256" column="file_sha256"/><result property="requiredFlag" column="required_flag"/><result property="verifyStatus" column="verify_status"/><result property="verifyUserId" column="verify_user_id"/><result property="verifyComment" column="verify_comment"/><result property="verifiedAt" column="verified_at"/><result property="uploadedBy" column="uploaded_by"/><result property="createdAt" column="created_at"/><result property="updatedAt" column="updated_at"/></resultMap>
 <sql id="cols">material_id,application_id,material_type,material_name,original_filename,stored_filename,storage_path,content_type,file_size,file_sha256,required_flag,verify_status,verify_user_id,verify_comment,verified_at,uploaded_by,created_at,updated_at</sql>
 <insert id="insert" useGeneratedKeys="true" keyProperty="materialId">INSERT INTO application_material(application_id,material_type,material_name,original_filename,stored_filename,storage_path,content_type,file_size,file_sha256,required_flag,verify_status,uploaded_by) VALUES(#{applicationId},#{materialType},#{materialName},#{originalFilename},#{storedFilename},#{storagePath},#{contentType},#{fileSize},#{fileSha256},#{requiredFlag},#{verifyStatus},#{uploadedBy})</insert>
 <select id="selectById" resultMap="map">SELECT <include refid="cols"/> FROM application_material WHERE material_id=#{id}</select>
 <select id="selectByApplicationId" resultMap="map">SELECT <include refid="cols"/> FROM application_material WHERE application_id=#{applicationId} ORDER BY material_id</select>
 <select id="countRequired" resultType="long">SELECT COUNT(*) FROM application_material WHERE application_id=#{applicationId} AND required_flag=1</select>
 <select id="countRequiredNotVerified" resultType="long">SELECT COUNT(*) FROM application_material WHERE application_id=#{applicationId} AND required_flag=1 AND verify_status!='VERIFIED'</select>
 <delete id="deleteById">DELETE FROM application_material WHERE material_id=#{id}</delete>
 <update id="verify">UPDATE application_material SET verify_status=#{status},verify_user_id=#{userId},verify_comment=#{comment},verified_at=CURRENT_TIMESTAMP,updated_at=CURRENT_TIMESTAMP WHERE material_id=#{id} AND verify_status='PENDING'</update>
</mapper>
