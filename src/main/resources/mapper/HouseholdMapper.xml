<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.population.mapper.HouseholdMapper">

    <select id="findByHouseholdNoForUpdate" resultType="com.example.population.entity.Household">
        SELECT * FROM household WHERE household_no = #{householdNo} LIMIT 1 FOR UPDATE
    </select>

</mapper>
