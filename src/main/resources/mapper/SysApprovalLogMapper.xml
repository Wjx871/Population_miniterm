<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.population.mapper.SysApprovalLogMapper">

    <select id="selectMaxStepNo" resultType="java.lang.Integer">
        SELECT MAX(step_no) FROM sys_approval_log WHERE approval_id = #{approvalId}
    </select>

</mapper>
