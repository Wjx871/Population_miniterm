# 人口数据库管理系统 - 本地启动配置示例
#
# 用法：
#   copy config\start.local.env.example start.local.env
#   用记事本编辑 start.local.env，至少填写 DB_PASSWORD
#   双击项目根目录的 start.bat 一键启动前后端
#
# start.local.env 含密码，请勿提交到 Git（已在 .gitignore 中忽略）。

DB_USERNAME=root
DB_PASSWORD=CHANGE_ME

# 数据库连接 URL（createDatabaseIfNotExist=true 会自动建库）
DB_URL=jdbc:mysql://localhost:3306/population_miniterm?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&createDatabaseIfNotExist=true

# 后端端口（Spring Boot server.port）
SERVER_PORT=8080

# 前端端口（Vite dev server）
FRONTEND_PORT=5180

# JWT 密钥，至少 32 字节，生产环境必须替换为随机密钥
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET_AT_LEAST_32_BYTES_LONG

# JWT 过期时间（分钟）
JWT_EXPIRE_MINUTES=120
